# =============================================================================
# Multi-Model Personal Travel Agent — environment variables
# Copy this file to .env (or set as system environment) and fill in your keys.
# Never commit .env to git.
# =============================================================================

# --- Telegram Bot ---
# Create at @BotFather on Telegram, then put the token here.
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID (the bot will only respond to this ID).
# To get it: send a message to your bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates and look for "chat":{"id":...}
TELEGRAM_CHAT_ID=

# --- Duffel (flight search) ---
# Sign up at https://app.duffel.com/join → Settings → API access tokens.
# Use a "live" token with read+write scope for real-time prices.
# Test token works for development with limited stub data.
DUFFEL_API_KEY=

# --- Google Maps Platform ---
# Enable Routes API at https://console.cloud.google.com/apis/library/routes.googleapis.com
# Create an API key at Credentials, restrict to Routes API.
GOOGLE_MAPS_API_KEY=

# --- OpenAI ---
# https://platform.openai.com/api-keys
# Used for Extract Params node (gpt-4o-mini) AND research node (gpt-4o).
OPENAI_API_KEY=

# --- Google Gemini ---
# https://aistudio.google.com/apikey
# Free tier sufficient for personal use.
# Also used by the local research mode (scrapegraph/ tools).
GEMINI_API_KEY=

# (Optional) Override the model used by the local ScrapeGraphAI tools.
# Default: google_genai/gemini-2.5-flash-lite
# SCRAPEGRAPH_MODEL=google_genai/gemini-2.5-flash

# --- Perplexity ---
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# --- Notion ---
# Create a Notion integration at https://www.notion.so/my-integrations
# Then share your Travel parent page with that integration (top-right "Connect to integration").
NOTION_API_TOKEN=

# Notion page IDs for Travel structure (see notion/travel-structure.md).
# After creating the pages, copy each page's ID from its URL (32-char hex).
NOTION_TRAVEL_INSPIRATIONS_ID=
NOTION_TRAVEL_PLANNING_ID=
NOTION_TRAVEL_BUSINESS_WORK_ID=
NOTION_TRAVEL_READY_ID=
NOTION_TRAVEL_PAST_TRIPS_ID=

# --- n8n ---
# Local URL where your n8n instance runs.
N8N_BASE_URL=http://localhost:5678

# --- (Optional) ElevenLabs for voice replies ---
# https://elevenlabs.io/api → API Key
ELEVENLABS_API_KEY=
